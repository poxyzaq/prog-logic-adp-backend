.vscode/

# Helix
*.swp
*.swo
*~

# OS - Linux
.directory
# OS - macOS
.DS_Store
# OS - Windows
Thumbs.db
desktop.ini

# Logs & diagnostics
*.log
*.trace
crash-*.txt

# dotnet tools
.config/dotnet-tools.json
.dotnet/

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml

# Publish output
publish/
*.pubxml
*.pubxml.user
